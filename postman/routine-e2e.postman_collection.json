      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Customer register status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Customer register returns token and id', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.success).to.eql(true);",
              "  pm.expect(body.data).to.have.property('token');",
              "  pm.expect(body.data).to.have.property('refreshToken');",
              "  pm.expect(body.data).to.have.property('id');",
              "  pm.collectionVariables.set('customerToken', body.data.token);",
              "  pm.collectionVariables.set('customerRefreshToken', body.data.refreshToken);",
              "  pm.collectionVariables.set('createdCustomerId', String(body.data.id));",
              "});"
            ]
          }
        }
