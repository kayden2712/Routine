{
  "info": {
    "_postman_id": "5e6f1ce8-3f73-4b0f-a625-099f8f1f4c01",
    "name": "Routine BE E2E Data-Driven",
    "description": "Collection test end-to-end cho backend Routine. Co the chay bang Collection Runner/Newman voi file data JSON de test nhieu bo du lieu.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const data = pm.iterationData ? pm.iterationData.toObject() : {};",
          "const existingRunId = pm.collectionVariables.get('runId');",
          "const runId = existingRunId || String(Date.now());",
          "pm.collectionVariables.set('runId', runId);",
          "",
          "const iteration = typeof pm.info.iteration === 'number' ? pm.info.iteration : 0;",
          "const email = data.customerEmail || `e2e.customer.${runId}.${iteration}@example.com`;",
          "",
          "pm.collectionVariables.set('customerEmail', email);",
          "pm.collectionVariables.set('customerPassword', data.customerPassword || 'Aa@12345');",
          "pm.collectionVariables.set('customerFullName', data.customerFullName || `E2E Customer ${iteration}`);",
          "pm.collectionVariables.set('customerPhone', data.customerPhone || `090000${String(100 + iteration).padStart(4, '0')}`);",
          "pm.collectionVariables.set('searchQuery', data.searchQuery || 'shirt');",
          "pm.collectionVariables.set('cartQuantity', String(data.cartQuantity || 2));",
          "pm.collectionVariables.set('cartQuantityUpdate', String(data.cartQuantityUpdate || 3));",
          "pm.collectionVariables.set('orderQuantity', String(data.orderQuantity || 1));",
          "pm.collectionVariables.set('paymentMethod', data.paymentMethod || 'CASH');",
          "",
          "if (!pm.collectionVariables.get('managerEmail')) {",
          "  pm.collectionVariables.set('managerEmail', 'manager@example.com');",
          "}",
          "if (!pm.collectionVariables.get('managerPassword')) {",
          "  pm.collectionVariables.set('managerPassword', 'Aa@12345');",
          "}",
          "",
          "const productCode = data.productCode || `E2E-${runId}-${iteration}`;",
          "pm.collectionVariables.set('managedProductCode', productCode);",
          "pm.collectionVariables.set('managedProductName', data.productName || `E2E Product ${iteration}`);",
          "pm.collectionVariables.set('managedProductPriceInput', String(data.productPrice || 299000));",
          "pm.collectionVariables.set('managedProductStock', String(data.productStock || 20));",
          "pm.collectionVariables.set('managedProductMinStock', String(data.productMinStock || 5));"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "managerEmail",
      "value": "manager@example.com"
    },
    {
      "key": "managerPassword",
      "value": "Aa@12345"
    }
  ],
  "item": [
    {
      "name": "01 Public - Get Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/categories",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "categories"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Categories status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Categories response structure is valid', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body.success).to.eql(true);",
              "  pm.expect(body.data).to.be.an('array');",
              "  pm.expect(body.data.length).to.be.above(0);",
              "  pm.collectionVariables.set('categoryId', String(body.data[0].id));",
              "});"
            ]
          }
        }
      ]
    },
