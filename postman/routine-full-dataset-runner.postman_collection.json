{
  "info": {
    "_postman_id": "53ca876c-4ab2-4e2d-a795-d80a7df0662e",
    "name": "Routine Seed Runner - Postman Free (Single File)",
    "description": "Seed a full end-to-end dataset with run-specific values on every execution: categories mapping, 30 products (10 sale with an auto-generated date window), 10 customers, 20 online orders, 30 offline orders, and sale auto-revert sync.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "adminEmail", "value": "admin@routine.com" },
    { "key": "adminPassword", "value": "admin123" },

    { "key": "saleStartDate", "value": "2026-03-01" },
    { "key": "saleEndDate", "value": "2026-04-30" },

    { "key": "runId", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "loginAttemptIndex", "value": "0" },
    { "key": "adminCandidates", "value": "[{\"email\":\"admin@routine.com\",\"password\":\"admin123\"},{\"email\":\"admin@example.com\",\"password\":\"admin123\"},{\"email\":\"manager@routine.com\",\"password\":\"admin123\"}]" },

    { "key": "categoryMap", "value": "{}" },
    { "key": "categoryEnsureSeeds", "value": "[]" },
    { "key": "categoryEnsureIndex", "value": "0" },
    { "key": "currentCategoryBody", "value": "{}" },

    { "key": "productSeeds", "value": "[]" },
    { "key": "customerSeeds", "value": "[]" },
    { "key": "orderSeeds", "value": "[]" },
    { "key": "offlineOrderSeeds", "value": "[]" },

    { "key": "seededProducts", "value": "[]" },
    { "key": "seededCustomers", "value": "[]" },

    { "key": "productIndex", "value": "0" },
    { "key": "customerIndex", "value": "0" },
    { "key": "orderIndex", "value": "0" },
    { "key": "offlineOrderIndex", "value": "0" },
    { "key": "saleSyncIndex", "value": "0" },

    { "key": "currentProductBody", "value": "{}" },
    { "key": "currentCustomerBody", "value": "{}" },
    { "key": "currentCustomerToken", "value": "" },
    { "key": "currentOrderBody", "value": "{}" },
    { "key": "currentOfflineOrderBody", "value": "{}" },
    { "key": "currentSyncBody", "value": "{}" }
  ],
  "item": [
    {
      "name": "00 Init Run",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/categories"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "const runId = `${Date.now()}-${Math.floor(Math.random() * 1000).toString().padStart(3, '0')}`;",
              "pm.collectionVariables.set('runId', runId);",
              "const formatDate = (date) => {",
              "  const year = date.getFullYear();",
              "  const month = String(date.getMonth() + 1).padStart(2, '0');",
              "  const day = String(date.getDate()).padStart(2, '0');",
              "  return `${year}-${month}-${day}`;",
              "};",
              "const today = new Date();",
              "const saleStart = new Date(today);",
              "saleStart.setDate(saleStart.getDate() - 3);",
              "const saleEnd = new Date(today);",
              "saleEnd.setDate(saleEnd.getDate() + 14);",
              "pm.collectionVariables.set('saleStartDate', formatDate(saleStart));",
              "pm.collectionVariables.set('saleEndDate', formatDate(saleEnd));",
              "pm.collectionVariables.set('productIndex', '0');",
              "pm.collectionVariables.set('customerIndex', '0');",
              "pm.collectionVariables.set('orderIndex', '0');",
              "pm.collectionVariables.set('offlineOrderIndex', '0');",
              "pm.collectionVariables.set('saleSyncIndex', '0');",
              "pm.collectionVariables.set('loginAttemptIndex', '0');",
              "pm.collectionVariables.set('categoryEnsureIndex', '0');",
              "pm.collectionVariables.set('adminToken', '');",
              "pm.collectionVariables.set('currentCustomerToken', '');",
              "pm.collectionVariables.set('orderVariantStockMap', '{}');",
              "pm.collectionVariables.set('seededProducts', '[]');",
              "pm.collectionVariables.set('seededCustomers', '[]');",
              "postman.setNextRequest('01 Admin Login');"
            ]
          }
        }
      ]
    },

    {
      "name": "01 Admin Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": "{{baseUrl}}/auth/admin/login"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let candidates = [];",
              "try {",
              "  candidates = JSON.parse(pm.collectionVariables.get('adminCandidates') || '[]');",
              "} catch (e) {",
              "  candidates = [];",
              "}",
              "if (!Array.isArray(candidates) || candidates.length === 0) {",
              "  candidates = [{ email: 'admin@routine.com', password: 'admin123' }];",
              "}",
              "const idx = Number(pm.collectionVariables.get('loginAttemptIndex') || '0');",
              "const chosen = candidates[Math.min(idx, candidates.length - 1)] || candidates[0];",
              "pm.variables.set('adminEmail', chosen.email);",
              "pm.variables.set('adminPassword', chosen.password);",
              "pm.collectionVariables.set('adminEmail', chosen.email);",
              "pm.collectionVariables.set('adminPassword', chosen.password);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let json = {};",
              "try { if (pm.response.code === 200 || pm.response.code === 201) { json = pm.response.json(); } } catch (e) { json = {}; }",
              "const token = (json.data && json.data.token) || '';",
              "if (token) {",
              "  pm.collectionVariables.set('adminToken', token);",
              "  pm.test('Admin login success', function () { pm.expect(token).to.not.eql(''); });",
              "  postman.setNextRequest('02 Ensure Categories - Prepare');",
              "} else {",
              "  let candidates = [];",
              "  try { candidates = JSON.parse(pm.collectionVariables.get('adminCandidates') || '[]'); } catch (e) { candidates = []; }",
              "  const idx = Number(pm.collectionVariables.get('loginAttemptIndex') || '0');",
              "  const nextIdx = idx + 1;",
              "  const message = (json && (json.message || json.error)) || 'Login failed';",
              "  if (nextIdx < Math.max(1, candidates.length)) {",
              "    pm.collectionVariables.set('loginAttemptIndex', String(nextIdx));",
              "    postman.setNextRequest('01 Admin Login');",
              "  } else {",
              "    pm.test('Admin login failed after trying default accounts', function () {",
              "      pm.expect.fail('Khong dang nhap duoc admin. Hay cap nhat adminEmail/adminPassword trong collection variables. Chi tiet: ' + message);",
              "    });",
              "    postman.setNextRequest(null);",
              "  }",
              "}"
            ]
          }
        }
      ]
    },

    {
      "name": "02 Ensure Categories - Prepare",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/categories"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "let json = {};",
              "try { if (pm.response.code === 200) { json = pm.response.json(); } } catch (e) { json = {}; }",
              "const categories = Array.isArray(json.data) ? json.data : [];",
              "const normalize = (s) => String(s || '').normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').toLowerCase().trim();",
              "const required = [",
              "  { name: 'Ao so mi', description: 'Nhom ao so mi, ao phong, polo', icon: 'shirt', displayOrder: 1 },",
              "  { name: 'Ao khoac', description: 'Nhom ao khoac ngoai', icon: 'jacket', displayOrder: 2 },",
              "  { name: 'Quan jeans', description: 'Nhom quan jeans', icon: 'jeans', displayOrder: 3 },",
              "  { name: 'Quan kaki', description: 'Nhom quan kaki', icon: 'khaki', displayOrder: 4 },",
              "  { name: 'Vay', description: 'Nhom vay dam nu', icon: 'dress', displayOrder: 5 },",
              "  { name: 'Phu kien', description: 'Nhom phu kien', icon: 'accessory', displayOrder: 6 }",
              "];",
              "const existingNames = categories.map((c) => normalize(c.name));",
              "const missing = required.filter((r) => !existingNames.includes(normalize(r.name)));",
              "pm.collectionVariables.set('categoryEnsureSeeds', JSON.stringify(missing));",
              "pm.collectionVariables.set('categoryEnsureIndex', '0');",
              "if (missing.length > 0) {",
              "  postman.setNextRequest('02 Ensure Categories - Create Loop');",
              "} else {",
              "  postman.setNextRequest('02 Build Dataset From Categories');",
              "}"
            ]
          }
        }
      ]
    },

    {
      "name": "02 Ensure Categories - Create Loop",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{currentCategoryBody}}"
        },
        "url": "{{baseUrl}}/categories"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const seeds = JSON.parse(pm.collectionVariables.get('categoryEnsureSeeds') || '[]');",
              "const idx = Number(pm.collectionVariables.get('categoryEnsureIndex') || '0');",
              "if (idx >= seeds.length) {",
              "  postman.setNextRequest('02 Build Dataset From Categories');",
              "  return;",
              "}",
              "pm.collectionVariables.set('currentCategoryBody', JSON.stringify(seeds[idx]));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(201);",
              "const idx = Number(pm.collectionVariables.get('categoryEnsureIndex') || '0');",
              "pm.collectionVariables.set('categoryEnsureIndex', String(idx + 1));",
              "postman.setNextRequest('02 Ensure Categories - Create Loop');"
            ]
          }
        }
      ]
    },

    {
      "name": "02 Build Dataset From Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/categories"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "let body = {};",
              "try { if (pm.response.code === 200) { body = pm.response.json(); } } catch (e) { body = {}; }",
              "const categories = (body && body.data) || [];",
              "if (!Array.isArray(categories) || categories.length === 0) {",
              "  postman.setNextRequest(null);",
              "  return;",
              "}",
              "",
              "const normalize = (s) => String(s || '').normalize('NFD').replace(/[\\u0300-\\u036f]/g, '').toLowerCase().trim();",
              "const findCategoryId = (keywords) => {",
              "  const keyNorm = keywords.map(normalize);",
              "  const found = categories.find((c) => {",
              "    const n = normalize(c.name);",
              "    return keyNorm.some((k) => n.includes(k));",
              "  });",
              "  return found ? found.id : categories[0].id;",
              "};",
              "",
              "const categoryMap = {",
              "  shirt: findCategoryId(['ao so mi', 'so mi', 'ao phong', 'thun', 'polo']),",
              "  jacket: findCategoryId(['ao khoac', 'khoac', 'jacket']),",
              "  jeans: findCategoryId(['quan jean', 'jean', 'jeans']),",
              "  khaki: findCategoryId(['quan kaki', 'kaki']),",
              "  dress: findCategoryId(['vay', 'dam', 'dress']),",
              "  accessory: findCategoryId(['phu kien', 'accessory'])",
              "};",
              "pm.collectionVariables.set('categoryMap', JSON.stringify(categoryMap));",
              "",
              "const saleStart = pm.collectionVariables.get('saleStartDate');",
              "const saleEnd = pm.collectionVariables.get('saleEndDate');",
              "const now = new Date();",
              "const startAt = new Date(`${saleStart}T00:00:00`);",
              "const endAt = new Date(`${saleEnd}T23:59:59`);",
              "const inSaleWindow = now >= startAt && now <= endAt;",
              "",
              "const productTemplates = [",
              "  { key: 'shirt', label: 'Ao so mi', image: 'https://images.unsplash.com/photo-1598033129183-c4b91b1c0f58?auto=format&fit=crop&w=1200&q=80', colors: ['white','black','blue','gray'], sizes: ['S','M','L','XL'] },",
              "  { key: 'shirt', label: 'Ao phong', image: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=1200&q=80', colors: ['white','black','red','green'], sizes: ['S','M','L','XL'] },",
              "  { key: 'shirt', label: 'Ao polo', image: 'https://images.unsplash.com/photo-1576566588028-4147f3842f27?auto=format&fit=crop&w=1200&q=80', colors: ['navy','white','gray'], sizes: ['M','L','XL','XXL'] },",
              "  { key: 'jacket', label: 'Ao khoac', image: 'https://images.unsplash.com/photo-1591047139829-d91aecb6caea?auto=format&fit=crop&w=1200&q=80', colors: ['black','beige','olive'], sizes: ['M','L','XL','XXL'] },",
              "  { key: 'jeans', label: 'Quan jeans', image: 'https://images.unsplash.com/photo-1542272604-787c3835535d?auto=format&fit=crop&w=1200&q=80', colors: ['blue','black','gray'], sizes: ['28','29','30','31','32'] },",
              "  { key: 'khaki', label: 'Quan kaki', image: 'https://images.unsplash.com/photo-1473966968600-fa801b869a1a?auto=format&fit=crop&w=1200&q=80', colors: ['beige','brown','black'], sizes: ['28','29','30','31','32'] },",
              "  { key: 'dress', label: 'Vay', image: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?auto=format&fit=crop&w=1200&q=80', colors: ['red','black','white','pink'], sizes: ['S','M','L','XL'] },",
              "  { key: 'accessory', label: 'Phu kien', image: 'https://images.unsplash.com/photo-1523170335258-f5ed11844a49?auto=format&fit=crop&w=1200&q=80', colors: ['black','brown','gray'], sizes: ['M'] }",
              "];",
              "",
              "const products = [];",
              "for (let i = 0; i < 30; i += 1) {",
              "  const t = productTemplates[i % productTemplates.length];",
              "  const no = String(i + 1).padStart(2, '0');",
              "  const basePrice = 199000 + i * 10000;",
              "  const salePercent = i < 10 ? (10 + (i % 5) * 5) : 0;",
              "  const salePrice = Math.round(basePrice * (1 - salePercent / 100));",
              "",
              "  let finalPrice = basePrice;",
              "  let oldPrice = null;",
              "  if (salePercent > 0 && inSaleWindow) {",
              "    finalPrice = salePrice;",
              "    oldPrice = basePrice;",
              "  }",
              "",
              "  const variants = [];",
              "  const maxVariants = Math.min(5, Math.max(2, t.sizes.length));",
              "  for (let v = 0; v < maxVariants; v += 1) {",
              "    variants.push({",
              "      size: t.sizes[v % t.sizes.length],",
              "      color: t.colors[v % t.colors.length],",
              "      stock: 5 + ((i + v) % 20)",
              "    });",
              "  }",
              "",
              "  products.push({",
              "    code: `SEED-${pm.collectionVariables.get('runId').slice(-6)}-${no}`,",
              "    name: `${t.label} ${no}`,",
              "    categoryId: categoryMap[t.key],",
              "    description: `${t.label} ${no} - Sale ${saleStart} den ${saleEnd}. Qua han se ve gia goc tu dong khi chay request sync sale.` ,",
              "    price: finalPrice,",
              "    oldPrice: oldPrice,",
              "    costPrice: Math.round(basePrice * 0.62),",
              "    stock: variants.reduce((s, x) => s + x.stock, 0),",
              "    minStock: 5 + (i % 4),",
              "    imageUrl: t.image,",
              "    imageUrls: [t.image],",
              "    material: t.key === 'jeans' ? 'Denim' : 'Cotton',",
              "    fit: t.key === 'dress' ? 'Slim fit' : 'Regular fit',",
              "    season: i % 2 === 0 ? 'All' : 'Summer',",
              "    careInstructions: 'Machine wash cold',",
              "    gender: i % 2 === 0 ? 'MALE' : 'FEMALE',",
              "    sizes: t.sizes,",
              "    colors: t.colors,",
              "    variants: variants,",
              "    __meta: {",
              "      key: t.key,",
              "      basePrice: basePrice,",
              "      salePercent: salePercent,",
              "      saleStart: saleStart,",
              "      saleEnd: saleEnd",
              "    }",
              "  });",
              "}",
              "",
              "const customers = [];",
              "const runId = pm.collectionVariables.get('runId');",
              "for (let i = 0; i < 10; i += 1) {",
              "  const no = String(i + 1).padStart(2, '0');",
              "  customers.push({",
              "    fullName: `Seed Customer ${no}`,",
              "    email: `seed.customer.${runId}.${no}@routine.vn`,",
              "    password: 'Aa@12345',",
              "    phone: `09${runId.slice(-6)}${no}`",
              "  });",
              "}",
              "",
              "const orders = [];",
              "for (let i = 0; i < 20; i += 1) {",
              "  orders.push({",
              "    customerSeedIndex: i % 10,",
              "    productSeedIndex: i % 30,",
              "    quantity: 1 + (i % 3),",
              "    paymentMethod: ['COD', 'BANK'][i % 2],",
              "    notes: `Seed order ${String(i + 1).padStart(2, '0')} by run ${runId}`",
              "  });",
              "}",
              "",
              "const offlineOrders = [];",
              "for (let i = 0; i < 30; i += 1) {",
              "  offlineOrders.push({",
              "    customerSeedIndex: i % 10,",
              "    productSeedIndex: (i * 2) % 30,",
              "    quantity: 1 + (i % 2),",
              "    paymentMethod: ['CASH', 'TRANSFER'][i % 2],",
              "    notes: `Seed offline order ${String(i + 1).padStart(2, '0')} by run ${runId}`",
              "  });",
              "}",
              "",
              "pm.collectionVariables.set('productSeeds', JSON.stringify(products));",
              "pm.collectionVariables.set('customerSeeds', JSON.stringify(customers));",
              "pm.collectionVariables.set('orderSeeds', JSON.stringify(orders));",
              "pm.collectionVariables.set('offlineOrderSeeds', JSON.stringify(offlineOrders));",
              "",
              "pm.test('Seed data built', function () {",
              "  pm.expect(products.length).to.eql(30);",
              "  pm.expect(customers.length).to.eql(10);",
              "  pm.expect(orders.length).to.eql(20);",
              "  pm.expect(offlineOrders.length).to.eql(30);",
              "});",
              "",
              "postman.setNextRequest('03 Seed Products (Loop 30)');"
            ]
          }
        }
      ]
    },

    {
      "name": "03 Seed Products (Loop 30)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{currentProductBody}}"
        },
        "url": "{{baseUrl}}/products"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const seeds = JSON.parse(pm.collectionVariables.get('productSeeds') || '[]');",
              "const idx = Number(pm.collectionVariables.get('productIndex') || '0');",
              "if (idx >= seeds.length) {",
              "  postman.setNextRequest('04 Seed Customers (Loop 10)');",
              "  return;",
              "}",
              "const body = { ...seeds[idx] };",
              "const runId = pm.collectionVariables.get('runId') || String(Date.now());",
              "const no = String(idx + 1).padStart(2, '0');",
              "const nonce = Math.floor(Math.random() * 900 + 100);",
              "body.code = `SEED-${runId.slice(-6)}-${no}-${nonce}`;",
              "delete body.__meta;",
              "pm.collectionVariables.set('currentProductBody', JSON.stringify(body));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(201);",
              "let res = {};",
              "try { if (pm.response.code === 201) { res = pm.response.json(); } } catch (e) { res = {}; }",
              "const data = (res && res.data) || {};",
              "const idx = Number(pm.collectionVariables.get('productIndex') || '0');",
              "const seeds = JSON.parse(pm.collectionVariables.get('productSeeds') || '[]');",
              "const seededProducts = JSON.parse(pm.collectionVariables.get('seededProducts') || '[]');",
              "if (data.id) {",
              "  seededProducts.push({",
              "    id: data.id,",
              "    code: data.code || seeds[idx].code,",
              "    name: data.name || seeds[idx].name,",
              "    categoryId: seeds[idx].categoryId,",
              "    basePrice: seeds[idx].__meta.basePrice,",
              "    salePercent: seeds[idx].__meta.salePercent,",
              "    saleStart: seeds[idx].__meta.saleStart,",
              "    saleEnd: seeds[idx].__meta.saleEnd,",
              "    templateKey: seeds[idx].__meta.key,",
              "    imageUrl: seeds[idx].imageUrl,",
              "    material: seeds[idx].material,",
              "    fit: seeds[idx].fit,",
              "    season: seeds[idx].season,",
              "    careInstructions: seeds[idx].careInstructions,",
              "    gender: seeds[idx].gender,",
              "    sizes: seeds[idx].sizes,",
              "    colors: seeds[idx].colors,",
              "    variants: seeds[idx].variants",
              "  });",
              "  pm.collectionVariables.set('seededProducts', JSON.stringify(seededProducts));",
              "}",
              "pm.collectionVariables.set('productIndex', String(idx + 1));",
              "postman.setNextRequest('03 Seed Products (Loop 30)');"
            ]
          }
        }
      ]
    },

    {
      "name": "04 Seed Customers (Loop 10)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{currentCustomerBody}}"
        },
        "url": "{{baseUrl}}/auth/customer/register"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const seeds = JSON.parse(pm.collectionVariables.get('customerSeeds') || '[]');",
              "const idx = Number(pm.collectionVariables.get('customerIndex') || '0');",
              "if (idx >= seeds.length) {",
              "  postman.setNextRequest('05 Seed Online Orders (Loop 20)');",
              "  return;",
              "}",
              "pm.collectionVariables.set('currentCustomerBody', JSON.stringify(seeds[idx]));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "let res = {};",
              "try { if (pm.response.code === 200) { res = pm.response.json(); } } catch (e) { res = {}; }",
              "const data = (res && res.data) || {};",
              "const idx = Number(pm.collectionVariables.get('customerIndex') || '0');",
              "const seeds = JSON.parse(pm.collectionVariables.get('customerSeeds') || '[]');",
              "const seededCustomers = JSON.parse(pm.collectionVariables.get('seededCustomers') || '[]');",
              "if (data.id || (data.user && data.user.id)) {",
              "  seededCustomers.push({",
              "    id: data.id || (data.user && data.user.id),",
              "    token: data.token || '',",
              "    email: seeds[idx].email,",
              "    fullName: seeds[idx].fullName,",
              "    phone: seeds[idx].phone",
              "  });",
              "  pm.collectionVariables.set('seededCustomers', JSON.stringify(seededCustomers));",
              "}",
              "pm.collectionVariables.set('customerIndex', String(idx + 1));",
              "postman.setNextRequest('04 Seed Customers (Loop 10)');"
            ]
          }
        }
      ]
    },

    {
      "name": "05 Seed Online Orders (Loop 20)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{currentCustomerToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{currentOrderBody}}"
        },
        "url": "{{baseUrl}}/customer/orders"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const orderSeeds = JSON.parse(pm.collectionVariables.get('orderSeeds') || '[]');",
              "const products = JSON.parse(pm.collectionVariables.get('seededProducts') || '[]');",
              "const customers = JSON.parse(pm.collectionVariables.get('seededCustomers') || '[]');",
              "const idx = Number(pm.collectionVariables.get('orderIndex') || '0');",
              "if (idx >= orderSeeds.length) {",
              "  postman.setNextRequest('06 Seed Offline Orders (Loop 30)');",
              "  return;",
              "}",
              "",
              "const s = orderSeeds[idx];",
              "const customer = customers[s.customerSeedIndex];",
              "const product = products[s.productSeedIndex];",
              "if (!customer || !customer.token) {",
              "  pm.test('Customer token exists for online order', function () {",
              "    pm.expect.fail('Thieu token customer cho order index ' + idx + '. Hay kiem tra buoc register customer.');",
              "  });",
              "  postman.setNextRequest(null);",
              "  return;",
              "}",
              "pm.collectionVariables.set('currentCustomerToken', customer.token);",
              "const qty = s.quantity;",
              "let stockMap = {};",
              "try { stockMap = JSON.parse(pm.collectionVariables.get('orderVariantStockMap') || '{}'); } catch (e) { stockMap = {}; }",
              "const variants = (product.variants && product.variants.length > 0) ? product.variants : [{ size: 'M', color: 'black', stock: 999 }];",
              "variants.forEach((v) => {",
              "  const k = `${product.id}|${String(v.size)}|${String(v.color)}`;",
              "  if (stockMap[k] == null) { stockMap[k] = Number(v.stock || 0); }",
              "});",
              "const variantWithStock = variants",
              "  .map((v) => ({ ...v, __k: `${product.id}|${String(v.size)}|${String(v.color)}`, __remaining: Number(stockMap[`${product.id}|${String(v.size)}|${String(v.color)}`] || 0) }))",
              "  .sort((a, b) => b.__remaining - a.__remaining)[0];",
              "const variant = variantWithStock || variants[0];",
              "const chosenQty = Math.max(1, Math.min(Number(qty || 1), Number(variant.__remaining || variant.stock || 1)));",
              "pm.collectionVariables.set('currentOrderVariantKey', variant.__k || `${product.id}|${String(variant.size)}|${String(variant.color)}`);",
              "pm.collectionVariables.set('currentOrderQty', String(chosenQty));",
              "pm.collectionVariables.set('orderVariantStockMap', JSON.stringify(stockMap));",
              "const activePrice = (product.salePercent > 0 && (new Date() <= new Date(`${product.saleEnd}T23:59:59`) && new Date() >= new Date(`${product.saleStart}T00:00:00`)))",
              "  ? Math.round(product.basePrice * (1 - product.salePercent / 100))",
              "  : product.basePrice;",
              "const subtotal = activePrice * chosenQty;",
              "",
              "const body = {",
              "  items: [",
              "    {",
              "      productId: product.id,",
              "      quantity: chosenQty,",
              "      price: activePrice,",
              "      size: variant.size,",
              "      color: variant.color",
              "    }",
              "  ],",
              "  subtotal: subtotal,",
              "  discount: 0,",
              "  total: subtotal,",
              "  paymentMethod: s.paymentMethod,",
              "  notes: `${s.notes} | online customer: ${customer.email}`",
              "};",
              "",
              "pm.collectionVariables.set('currentOrderBody', JSON.stringify(body));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const status = pm.response.code;",
              "let body = {};",
              "try { if (status === 201 || status === 400) { body = pm.response.json(); } } catch (e) { body = {}; }",
              "const message = String((body && body.message) || '');",
              "if (status === 201) {",
              "  pm.response.to.have.status(201);",
              "  let stockMap = {};",
              "  try { stockMap = JSON.parse(pm.collectionVariables.get('orderVariantStockMap') || '{}'); } catch (e) { stockMap = {}; }",
              "  const k = pm.collectionVariables.get('currentOrderVariantKey') || '';",
              "  const q = Number(pm.collectionVariables.get('currentOrderQty') || '1');",
              "  if (k) { stockMap[k] = Math.max(0, Number(stockMap[k] || 0) - q); }",
              "  pm.collectionVariables.set('orderVariantStockMap', JSON.stringify(stockMap));",
              "} else if (status === 400 && /insufficient stock/i.test(message)) {",
              "  pm.response.to.have.status(400);",
              "} else {",
              "  pm.test('Create online order should succeed or skip by stock', function () {",
              "    pm.expect.fail(`Unexpected status ${status}. Message: ${message}`);",
              "  });",
              "}",
              "const idx = Number(pm.collectionVariables.get('orderIndex') || '0');",
              "pm.collectionVariables.set('orderIndex', String(idx + 1));",
              "postman.setNextRequest('05 Seed Online Orders (Loop 20)');"
            ]
          }
        }
      ]
    },

    {
      "name": "06 Seed Offline Orders (Loop 30)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{currentOfflineOrderBody}}"
        },
        "url": "{{baseUrl}}/orders"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const offlineOrderSeeds = JSON.parse(pm.collectionVariables.get('offlineOrderSeeds') || '[]');",
              "const products = JSON.parse(pm.collectionVariables.get('seededProducts') || '[]');",
              "const customers = JSON.parse(pm.collectionVariables.get('seededCustomers') || '[]');",
              "const idx = Number(pm.collectionVariables.get('offlineOrderIndex') || '0');",
              "if (idx >= offlineOrderSeeds.length) {",
              "  postman.setNextRequest('07 Sync Sale Status (Loop 10 sale products)');",
              "  return;",
              "}",
              "",
              "const s = offlineOrderSeeds[idx];",
              "const customer = customers[s.customerSeedIndex];",
              "const product = products[s.productSeedIndex];",
              "if (!customer || !customer.id) {",
              "  pm.test('Customer id exists for offline order', function () {",
              "    pm.expect.fail('Thieu customer id cho offline order index ' + idx + '. Hay kiem tra buoc seed customer.');",
              "  });",
              "  postman.setNextRequest(null);",
              "  return;",
              "}",
              "if (!product || !product.id) {",
              "  pm.test('Product exists for offline order', function () {",
              "    pm.expect.fail('Thieu product cho offline order index ' + idx + '. Hay kiem tra buoc seed product.');",
              "  });",
              "  postman.setNextRequest(null);",
              "  return;",
              "}",
              "",
              "let stockMap = {};",
              "try { stockMap = JSON.parse(pm.collectionVariables.get('orderVariantStockMap') || '{}'); } catch (e) { stockMap = {}; }",
              "const variants = (product.variants && product.variants.length > 0) ? product.variants : [{ size: 'M', color: 'black', stock: 999 }];",
              "variants.forEach((v) => {",
              "  const k = `${product.id}|${String(v.size)}|${String(v.color)}`;",
              "  if (stockMap[k] == null) { stockMap[k] = Number(v.stock || 0); }",
              "});",
              "const variantWithStock = variants",
              "  .map((v) => ({ ...v, __k: `${product.id}|${String(v.size)}|${String(v.color)}`, __remaining: Number(stockMap[`${product.id}|${String(v.size)}|${String(v.color)}`] || 0) }))",
              "  .sort((a, b) => b.__remaining - a.__remaining)[0];",
              "const variant = variantWithStock || variants[0];",
              "const chosenQty = Math.max(1, Math.min(Number(s.quantity || 1), Number(variant.__remaining || variant.stock || 1)));",
              "pm.collectionVariables.set('currentOrderVariantKey', variant.__k || `${product.id}|${String(variant.size)}|${String(variant.color)}`);",
              "pm.collectionVariables.set('currentOrderQty', String(chosenQty));",
              "pm.collectionVariables.set('orderVariantStockMap', JSON.stringify(stockMap));",
              "const activePrice = (product.salePercent > 0 && (new Date() <= new Date(`${product.saleEnd}T23:59:59`) && new Date() >= new Date(`${product.saleStart}T00:00:00`)))",
              "  ? Math.round(product.basePrice * (1 - product.salePercent / 100))",
              "  : product.basePrice;",
              "const subtotal = activePrice * chosenQty;",
              "",
              "const body = {",
              "  customerId: Number(customer.id),",
              "  items: [",
              "    {",
              "      productId: Number(product.id),",
              "      quantity: chosenQty,",
              "      price: activePrice,",
              "      size: variant.size,",
              "      color: variant.color",
              "    }",
              "  ],",
              "  subtotal: subtotal,",
              "  discount: 0,",
              "  total: subtotal,",
              "  paymentMethod: s.paymentMethod,",
              "  notes: `${s.notes} | offline customer: ${customer.email || customer.fullName || customer.id}`",
              "};",
              "",
              "pm.collectionVariables.set('currentOfflineOrderBody', JSON.stringify(body));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const status = pm.response.code;",
              "let body = {};",
              "try { if (status === 201 || status === 400) { body = pm.response.json(); } } catch (e) { body = {}; }",
              "const message = String((body && body.message) || '');",
              "if (status === 201) {",
              "  pm.response.to.have.status(201);",
              "  let stockMap = {};",
              "  try { stockMap = JSON.parse(pm.collectionVariables.get('orderVariantStockMap') || '{}'); } catch (e) { stockMap = {}; }",
              "  const k = pm.collectionVariables.get('currentOrderVariantKey') || '';",
              "  const q = Number(pm.collectionVariables.get('currentOrderQty') || '1');",
              "  if (k) { stockMap[k] = Math.max(0, Number(stockMap[k] || 0) - q); }",
              "  pm.collectionVariables.set('orderVariantStockMap', JSON.stringify(stockMap));",
              "} else if (status === 400 && /insufficient stock/i.test(message)) {",
              "  pm.response.to.have.status(400);",
              "} else {",
              "  pm.test('Create offline order should succeed or skip by stock', function () {",
              "    pm.expect.fail(`Unexpected status ${status}. Message: ${message}`);",
              "  });",
              "}",
              "const idx = Number(pm.collectionVariables.get('offlineOrderIndex') || '0');",
              "pm.collectionVariables.set('offlineOrderIndex', String(idx + 1));",
              "postman.setNextRequest('06 Seed Offline Orders (Loop 30)');"
            ]
          }
        }
      ]
    },

    {
      "name": "07 Sync Sale Status (Loop 10 sale products)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{currentSyncBody}}"
        },
        "url": "{{baseUrl}}/products/{{syncProductId}}"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const products = JSON.parse(pm.collectionVariables.get('seededProducts') || '[]');",
              "const idx = Number(pm.collectionVariables.get('saleSyncIndex') || '0');",
              "const saleProducts = products.filter((p) => Number(p.salePercent || 0) > 0).slice(0, 10);",
              "if (idx >= saleProducts.length) {",
              "  postman.setNextRequest('08 Verify Summary');",
              "  return;",
              "}",
              "",
              "const p = saleProducts[idx];",
              "const now = new Date();",
              "const startAt = new Date(`${p.saleStart}T00:00:00`);",
              "const endAt = new Date(`${p.saleEnd}T23:59:59`);",
              "const inWindow = now >= startAt && now <= endAt;",
              "const salePrice = Math.round(p.basePrice * (1 - p.salePercent / 100));",
              "const activePrice = inWindow ? salePrice : p.basePrice;",
              "const activeOldPrice = inWindow ? p.basePrice : null;",
              "",
              "const body = {",
              "  code: p.code,",
              "  name: p.name,",
              "  categoryId: p.categoryId,",
              "  description: `${p.name} - sale ${p.saleStart} den ${p.saleEnd}. ${inWindow ? 'Dang sale' : 'Het sale, da ve gia goc'}`,",
              "  price: activePrice,",
              "  oldPrice: activeOldPrice,",
              "  costPrice: Math.round(p.basePrice * 0.62),",
              "  stock: (p.variants || []).reduce((s, x) => s + Number(x.stock || 0), 0),",
              "  minStock: 5,",
              "  imageUrl: p.imageUrl,",
              "  imageUrls: [p.imageUrl],",
              "  material: p.material,",
              "  fit: p.fit,",
              "  season: p.season,",
              "  careInstructions: p.careInstructions,",
              "  gender: p.gender,",
              "  sizes: p.sizes,",
              "  colors: p.colors,",
              "  variants: p.variants",
              "};",
              "",
              "pm.collectionVariables.set('syncProductId', String(p.id));",
              "pm.collectionVariables.set('currentSyncBody', JSON.stringify(body));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "const idx = Number(pm.collectionVariables.get('saleSyncIndex') || '0');",
              "pm.collectionVariables.set('saleSyncIndex', String(idx + 1));",
              "postman.setNextRequest('07 Sync Sale Status (Loop 10 sale products)');"
            ]
          }
        }
      ]
    },

    {
      "name": "08 Verify Summary",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" }
        ],
        "url": "{{baseUrl}}/orders"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.response.to.have.status(200);",
              "const products = JSON.parse(pm.collectionVariables.get('seededProducts') || '[]');",
              "const customers = JSON.parse(pm.collectionVariables.get('seededCustomers') || '[]');",
              "pm.expect(products.length).to.eql(30);",
              "pm.expect(customers.length).to.eql(10);",
              "pm.expect(products.filter((p) => Number(p.salePercent || 0) > 0).length).to.be.at.least(10);",
              "postman.setNextRequest(null);"
            ]
          }
        }
      ]
    }
  ]
}
