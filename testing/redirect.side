  "version": "2.0",
  "name": "redirect",
  "url": "http://localhost:5173",
  "tests": [
    {
      "id": "t1-redirect-products-to-san-pham",
      "name": "redirect_01_products_to_san_pham",
      "commands": [
        {
          "id": "c1-1",
          "comment": "",
          "command": "open",
          "target": "/products",
          "targets": [],
          "value": ""
        },
        {
          "id": "c1-2",
          "comment": "",
          "command": "waitForElementPresent",
          "target": "xpath=//*[contains(text(), 'Sản phẩm')] | //*[contains(text(), 'Category')]",
          "targets": [["xpath=//*", "xpath:position"]],
          "value": "30000"
        }
      ]
    },
