{
  "id": "4c5d6e7f-8a9b-0c1d-2e3f-4a5b6c7d8e9f",
  "version": "2.0",
  "name": "wishlist",
  "url": "http://localhost:5173",
  "tests": [
    {
      "id": "t1-wishlist-empty-initial",
      "name": "wishlist_01_starts_empty",
      "commands": [
        {
          "id": "c1-0",
          "command": "executeScript",
          "target": "window.localStorage.clear(); window.sessionStorage.clear();",
          "value": ""
        },
        {
          "id": "c1-1",
          "command": "open",
          "target": "/yeu-thich",
          "value": ""
        },
        {
          "id": "c1-2",
          "command": "waitForElementPresent",
          "target": "xpath=//h1 | xpath=//h2",
          "value": "30000"
        }
      ]
    },
