{
  "id": "f5a8c2e1-9d4c-4b2a-8f1e-5c3d7e2f9a1b",
  "version": "2.0",
  "name": "login",
  "url": "http://localhost:5173",
  "tests": [{
    "id": "t1-login-success",
    "name": "login_01_success_correct_credentials",
    "commands": [{
      "id": "c1-0",
      "comment": "Clear session and local storage",
      "command": "executeScript",
      "target": "window.localStorage.clear(); window.sessionStorage.clear();",
      "targets": [],
      "value": ""
    }, {
      "id": "c1-1",
      "comment": "Open login page",
      "command": "open",
      "target": "/login",
      "targets": [],
      "value": ""
    }, {
      "id": "c1-2",
      "comment": "Wait for login form to load",
      "command": "waitForElementPresent",
      "target": "xpath=//h1[contains(.,'Đăng nhập')]",
      "targets": [],
      "value": "30000"
    }, {
      "id": "c1-3",
      "comment": "Enter correct email",
      "command": "type",
      "target": "xpath=//input[@placeholder='Email']",
      "targets": [],
      "value": "tung@gmail.com"
    }, {
      "id": "c1-4",
      "comment": "Enter correct password",
      "command": "type",
      "target": "xpath=//input[@placeholder='Mật khẩu']",
      "targets": [],
      "value": "Vutung123@"
    }, {
      "id": "3b49596a-6551-41b1-a106-af56ed3e65f4",
      "comment": "",
      "command": "click",
      "target": "css=.relative:nth-child(1) > .h-11",
      "targets": [
        ["css=.relative:nth-child(1) > .h-11", "css:finder"],
        ["xpath=//input[@value='']", "xpath:attributes"],
        ["xpath=//div[@id='root']/div/main/section/div/form/div/input", "xpath:idRelative"],
        ["xpath=//input", "xpath:position"]
      ],
      "value": ""
    }, {
      "id": "7d9ad732-5d8f-4353-a0d7-6380a4d4410e",
      "comment": "",
      "command": "click",
      "target": "css=.whitespace-nowrap",
      "targets": [
        ["css=.whitespace-nowrap", "css:finder"],
        ["xpath=//button[@type='submit']", "xpath:attributes"],
        ["xpath=//div[@id='root']/div/main/section/div/form/button", "xpath:idRelative"],
        ["xpath=//form/button", "xpath:position"],
        ["xpath=//button[contains(.,'Đăng nhập')]", "xpath:innerText"]
      ],
      "value": ""
    }, {
      "id": "c1-6",
      "comment": "Verify successful login - should be redirected to home or dashboard",
      "command": "verifyText",
      "target": "xpath=//p[contains(.,'Lịch sử đơn hàng')]",
      "targets": [],
      "value": "3000"
    }]
  }, {
